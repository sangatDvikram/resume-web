# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# The URL of the Next.js frontend (used for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# ─── Database — Neon PostgreSQL ───────────────────────────────────────────────
# Pooler endpoint — use for all runtime queries (PgBouncer in transaction mode)
# Format: postgresql://user:pass@ep-xyz-pooler.REGION.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://portfolio:dev_password@localhost:5432/portfolio_dev

# Direct (unpooled) connection — use ONLY for TypeORM migration CLI
# Never use this at runtime; DDL is incompatible with PgBouncer transaction mode
DATABASE_URL_UNPOOLED=postgresql://portfolio:dev_password@localhost:5432/portfolio_dev

# Pool configuration (for the pooler endpoint at runtime)
DB_POOL_MAX=10

# Set to 'true' ONLY in development to allow TypeORM auto-sync (never in production)
DB_SYNC=true

# ─── Authentication — JWT (RS256) ─────────────────────────────────────────────
# Generate: openssl genrsa -out private.pem 2048
# Access token TTL: 1 day (86400s)
JWT_ACCESS_TTL=86400

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...
-----END PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
-----END PUBLIC KEY-----"

# ─── ISR Revalidation ─────────────────────────────────────────────────────────
# Must match REVALIDATE_SECRET in apps/web/.env.local
REVALIDATE_SECRET=change-me-random-256-bit-hex
NEXT_REVALIDATE_URL=https://portfolio.vercel.app/api/revalidate

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get these from: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
