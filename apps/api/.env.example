# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# The URL of the Next.js frontend (used for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# ─── Database — Neon PostgreSQL ───────────────────────────────────────────────
# Pooler endpoint — use for all runtime queries (PgBouncer in transaction mode)
# Format: postgresql://user:pass@ep-xyz-pooler.REGION.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://portfolio:portfolio_pass@localhost:5432/portfolio_dev

# Direct (unpooled) connection — use ONLY for TypeORM migration CLI
# Never use this at runtime; DDL is incompatible with PgBouncer transaction mode
DATABASE_URL_UNPOOLED=postgresql://portfolio:portfolio_pass@localhost:5432/portfolio_dev

# Pool configuration (for the pooler endpoint at runtime)
DB_POOL_MAX=10

# Set to 'true' ONLY in development to allow TypeORM auto-sync (never in production)
DB_SYNC=true

# ─── Admin seed credentials ───────────────────────────────────────────────────
# Used by AdminUserService.onApplicationBootstrap() to create the first admin
# user when the admin_users table is empty.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# ─── Session ──────────────────────────────────────────────────────────────────
# Used by AdminJS session middleware.  Must be a long random string in production.
SESSION_SECRET=change-me-random-256-bit-hex
SESSION_COOKIE_NAME=adminjs

# ─── Rate limiting ────────────────────────────────────────────────────────────
# THROTTLE_TTL: sliding window in seconds
# THROTTLE_LIMIT: max requests per window
THROTTLE_TTL=60
THROTTLE_LIMIT=20

# ─── Authentication — JWT (RS256) ─────────────────────────────────────────────
# Generate: openssl genrsa -out private.pem 2048
# Access token TTL: 1 day
JWT_EXPIRES_IN=1d

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...
-----END PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
-----END PUBLIC KEY-----"

# ─── ISR Revalidation ─────────────────────────────────────────────────────────
# Must match REVALIDATE_SECRET in apps/web/.env.local
REVALIDATE_SECRET=change-me-random-256-bit-hex
NEXT_REVALIDATE_URL=https://portfolio.vercel.app/api/revalidate

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get these from: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
