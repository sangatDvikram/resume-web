{
  "name": "portfolio-cms",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "lerna run dev --parallel",
    "build": "lerna run build",
    "lint": "lerna run lint",
    "test": "lerna run test",
    "web": "yarn workspace web dev",
    "api": "yarn workspace api start:dev",
    "generate:openapi": "yarn workspace api generate:openapi",
    "generate:types": "yarn generate:openapi && openapi-typescript docs/openapi.json -o packages/types/src/api.d.ts && yarn workspace @portfolio-cms/types build"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "lerna": "^8.1.9",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "typeorm": "^0.3.28"
  }
}
