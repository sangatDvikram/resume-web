{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "yarn install --immutable",
  "buildCommand": "yarn workspace @portfolio-cms/types build && yarn workspace api build",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD apps/api packages/types yarn.lock package.json",
  "functions": {
    "apps/api/api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "apps/api/{dist/**,public/**},node_modules/{@adminjs/**,adminjs/**,swagger-ui-dist/**}"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/apps/api/api/index" }
  ]
}
